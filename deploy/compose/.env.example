# ─────────────────────────────────────────────────────────────────────────────
# loadify deployment variables — the ONE place to configure a deployment.
#
#   cd deploy/compose
#   cp .env.example .env        # then edit .env
#   docker compose up -d --build
#
# Run compose from THIS directory so the .env file is loaded automatically.
# Every value has a localhost/dev default in docker-compose.yml; uncomment and
# set here to override. .env is gitignored — never commit real secrets.
# NOTE: LOADIFY_API_BASE is baked into the web bundle at BUILD time, so re-run
# with --build after changing URLs.
# ─────────────────────────────────────────────────────────────────────────────

# --- Public URLs ------------------------------------------------------------
# Behind a reverse proxy on a domain (recommended): set both to your public URL;
# the browser then calls <domain>/api (same origin). Leave commented for a
# one-box localhost demo (defaults: http://localhost:8080 / http://localhost:3000).
#LOADIFY_API_BASE=https://loadify.example.com
#LOADIFY_FRONTEND_URL=https://loadify.example.com
# Timezone for server-rendered times (HTML report, run names, logs). The web
# UI already shows each viewer's own browser timezone; this only affects the
# server. Defaults to Asia/Shanghai; set an IANA zone for your deployment.
#LOADIFY_TZ=Asia/Shanghai

# --- Security (change for any real deployment) ------------------------------
#LOADIFY_JWT_SECRET=change-me            # e.g.  openssl rand -hex 32
#LOADIFY_ADMIN_EMAIL=admin@loadify.local
#LOADIFY_ADMIN_PASSWORD=admin12345

# --- Capacity / admission ---------------------------------------------------
#LOADIFY_MAX_CONCURRENT_RUNS=8           # concurrent runs before queueing
#LOADIFY_WORKER_CPU_MAX_PCT=85           # per-node CPU protection %, 0 = off
#LOADIFY_WORKER_ID=worker1               # node name in the UI (unique per box!)
#LOADIFY_WORKER_REGION=compose           # region label for this box's worker

# --- Extra worker nodes (docker-compose.worker.yml) -------------------------
# Only needed on ADDITIONAL load-generator boxes running the worker-only stack.
# Point each box at the central coordinator's gRPC port (keep 7070 on a private
# network). Give each box a UNIQUE LOADIFY_WORKER_ID (worker1 / worker2 / ...).
# Then: docker compose -f docker-compose.worker.yml up -d --build
#LOADIFY_COORDINATOR_GRPC=10.0.0.10:7070

# --- Feishu (Lark) OAuth (optional) -----------------------------------------
#LOADIFY_FEISHU_APP_ID=
#LOADIFY_FEISHU_APP_SECRET=
# Must exactly match the redirect URL registered in the Feishu app:
#LOADIFY_FEISHU_REDIRECT_URL=https://loadify.example.com/api/v1/auth/feishu/callback

# --- Build mirrors (restricted networks, e.g. China) ------------------------
# So `docker compose up --build` works without reaching gcr.io / proxy.golang.org
# / registry.npmjs.org directly. Defaults are the upstream registries.
#
# Runtime base image. The gcr distroless mirror (below) is often flaky. The
# build now copies CA certs from the Go builder image, so you can point this at
# ANY reachable minimal base — e.g. docker.io alpine, which is reliable in China
# and needs no gcr access at all. Prefer alpine if the daocloud mirror times out:
#LOADIFY_RUNTIME_BASE=alpine:3.20
# (gcr distroless via daocloud — smaller/nonroot, but the mirror can be unreachable)
#LOADIFY_RUNTIME_BASE=m.daocloud.io/gcr.io/distroless/static-debian12:nonroot
#LOADIFY_GOPROXY=https://goproxy.cn,direct
#LOADIFY_GOSUMDB=off
#LOADIFY_NPM_REGISTRY=https://registry.npmmirror.com
