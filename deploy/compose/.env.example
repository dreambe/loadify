# Copy to .env (next to this compose file) and fill in. .env is gitignored —
# never commit real secrets.

# Where browsers reach the frontend and the API (host or DNS name you bind).
LOADIFY_FRONTEND_URL=http://inner-loadify.cece.com:3000
LOADIFY_API_BASE=http://inner-loadify.cece.com:8080

# Feishu OAuth app credentials (open.feishu.cn -> your app -> credentials).
LOADIFY_FEISHU_APP_ID=
LOADIFY_FEISHU_APP_SECRET=
# Must exactly match the redirect URL registered in the Feishu app:
LOADIFY_FEISHU_REDIRECT_URL=http://inner-loadify.cece.com:8080/api/v1/auth/feishu/callback
